# Maintainer: Aditya Agrawal <aditya@example.com>
pkgname=uplink-cli-git
_pkgname=uplink-cli
pkgver=r11.5e81507
pkgrel=1
pkgdesc="High-Performance File-Sharing Go CLI Client for the R2-Uplink platform"
arch=('x86_64' 'aarch64' 'i686' 'armv7h')
url="https://github.com/AdityaAgrawal08/uplink-delta"
license=('MIT')
depends=('glibc')
makedepends=('go' 'git')
provides=('uplink')
conflicts=('uplink' 'storj-uplink')
source=("git+https://github.com/AdityaAgrawal08/uplink-delta.git")
sha256sums=('SKIP')

pkgver() {
  cd "uplink-delta"
  (
    set -o pipefail
    git describe --long --tags 2>/dev/null | sed 's/\([^-]*-\)g/r\1/;s/-/./g' || \
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
  )
}

build() {
  cd "uplink-delta/cli"
  export CGO_ENABLED=0
  go build -o uplink -ldflags="-s -w" main.go
}

package() {
  cd "uplink-delta/cli"
  install -Dm755 uplink "${pkgdir}/usr/bin/uplink"
}
