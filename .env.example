# Environment variables template for R2-Uplink
NODE_ENV=development
LOG_LEVEL=info
MAX_UPLOAD_SIZE=524288000
DEFAULT_EXPIRY=86400
UPLOAD_URL_EXPIRY=900
DOWNLOAD_URL_EXPIRY=60

# Cloudflare R2 Credentials
R2_ACCESS_KEY_ID=cf_access_key_here
R2_SECRET_ACCESS_KEY=cf_secret_key_here
R2_BUCKET_NAME=uplink-bucket
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# Database Connection (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/r2-uplink?retryWrites=true&w=majority

# Upstash Redis Connection (for Rate Limiting & Idempotency)
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Encryption / Hashing Secret (used for IP hashing)
IP_ANONYMIZATION_SECRET=change_me_to_a_secure_hmac_key_for_ip_masking

# Frontend App URL
APP_URL=http://localhost:3000
